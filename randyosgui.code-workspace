{
	"folders": [
		{
			"path": "."
		}
	],
	"settings": {
		"C_Cpp.intelliSenseEngine": "disabled",
		"C_Cpp.errorSquiggles": "disabled",
		"C_Cpp.autocomplete": "disabled",
		"C_Cpp.formatting": "disabled",
		"files.associations": {
			"*.c": "c",
			"*.h": "c",
			"*.inc": "c",
			"*.ipp": "cpp",
			"*.hpp": "cpp",
			"*.hh": "cpp"
		},
		"clangd.onConfigChanged": "restart",
		"clangd.arguments": [
			"--background-index",
			"--clang-tidy",
			"--header-insertion=never"
		],
		"C_Cpp.files.exclude": {
			"**/third_party/**": true
		},
		// "files.exclude": {
		// 	"**/third_party/**": true
		// },
		"files.watcherExclude": {
			"**/third_party/_downloads/**": true
		},
		"search.exclude": {
			"**/third_party/_downloads/**": true
		}
	},
	"extensions": {
		"recommendations": [
			"llvm-vs-code-extensions.vscode-clangd",
			"vadimcn.vscode-lldb"
		],
		"unwantedRecommendations": [
			"ms-vscode.cpptools"
		]
	},
	"tasks": {
		"version": "2.0.0",
		"tasks": [
			{
				"label": "zig: build",
				"type": "shell",
				"command": "zig",
				"args": [
					"build"
				],
				"group": "build",
				"problemMatcher": []
			}
		]
	},
	"launch": {
		"version": "0.2.0",
		"configurations": [
			{
				"type": "lldb",
				"request": "launch",
				"name": "Debug hello (LLDB)",
				"program": "${workspaceFolder}/zig-out/bin/hello.exe",
				"cwd": "${workspaceFolder}",
				"args": [],
				"preLaunchTask": "zig: build"
			}
		]
	}
}
